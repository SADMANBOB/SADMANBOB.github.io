{
  "name": "cg-websites",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:inspector && npm run build:contractor && npm run assemble && npm run build:search",
    "build:inspector": "cd inspector-site-prototype && VITE_BASE_PATH=/ VITE_SITE_ORIGIN=${SITE_ORIGIN:-https://www.cginspection.net} npm run build",
    "build:contractor": "cd contractor-site-prototype && VITE_BASE_PATH=/contracting/ VITE_SITE_ORIGIN=${SITE_ORIGIN:-https://www.cginspection.net} npm run build",
    "build:search": "node scripts/build-search-index.mjs",
    "assemble": "node scripts/assemble-site.mjs",
    "verify": "node scripts/verify-sites.mjs",
    "quality:static": "node scripts/quality-gates.mjs static",
    "quality": "npm run build && npm run verify && npm run quality:static",
    "audit:a11y": "node scripts/quality-gates.mjs browser-a11y",
    "audit:lighthouse": "lhci autorun --config=./lighthouserc.json",
    "readiness": "node scripts/publication-readiness.mjs",
    "release:verify": "node scripts/publication-readiness.mjs --require-publication",
    "test:browsers": "playwright test --config=./playwright.config.mjs",
    "test:browsers:smoke": "playwright test --config=./playwright.config.mjs --grep @smoke",
    "test:visual": "playwright test --config=./playwright.config.mjs --grep @visual",
    "test:visual:update": "playwright test --config=./playwright.config.mjs --grep @visual --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "parse5": "8.0.1",
    "pagefind": "1.5.2",
    "playwright": "1.61.1"
  }
}
