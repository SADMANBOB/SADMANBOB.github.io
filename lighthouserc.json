{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": [
        "http://localhost/",
        "http://localhost/services/",
        "http://localhost/contact/",
        "http://localhost/property-services/",
        "http://localhost/contracting/",
        "http://localhost/contracting/services/",
        "http://localhost/contracting/estimate/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "onlyCategories": [
          "accessibility",
          "best-practices",
          "performance",
          "seo"
        ],
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:performance": [
          "error",
          {
            "minScore": 0.75
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci/reports"
    }
  }
}
